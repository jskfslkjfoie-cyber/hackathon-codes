rules_version = '2';

// Prototype/demo rules: roles are a UI-only toggle, not real per-user auth.
// Anonymous Firebase Auth gates out anonymous internet/bot traffic; any
// signed-in client (incl. anonymous) can read/write within the app's own
// collections. Tighten to per-role rules before handling real patient data.
service cloud.firestore {
  match /databases/{database}/documents {
    match /patients/{patientId} {
      allow read, write: if request.auth != null;
      match /{subcollection=**} {
        allow read, write: if request.auth != null;
      }
    }
    match /hospitals/{hospitalId} {
      allow read, write: if request.auth != null;
    }
    match /emergencyRequests/{requestId} {
      allow read, write: if request.auth != null;
      match /{subcollection=**} {
        allow read, write: if request.auth != null;
      }
    }
    // DASH-003 uses a collection-group query across all patients/*/diary
    // subcollections; collection-group queries need an explicit rule at the
    // matching collection name (the nested rule above only covers per-patient access).
    match /{path=**}/diary/{diaryId} {
      allow read: if request.auth != null;
    }
  }
}
